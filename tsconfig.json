{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@proodos/domain/*": ["Domain/dist/*", "Domain/src/*"],
      "@proodos/application/*": ["Application/dist/*", "Application/src/*"],
      "@proodos/infrastructure/*": ["Infrastructure/dist/*", "Infrastructure/src/*"],
      "@proodos/api/*": ["API/dist/*", "API/src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": false
  }
}

