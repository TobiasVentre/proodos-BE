{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@proodos/domain/*": ["../Domain/dist/*"],
      "@proodos/application/*": ["../Application/dist/*"],
      "@proodos/infrastructure/*": ["../Infrastructure/dist/*"],
      "@proodos/api/*": ["src/*"]
    },
    "rootDir": "src",
    "outDir": "./dist",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "**/*.test.ts"]
}
