NODE_ENV=production
PORT=8000
CORS_ORIGIN=*
ENABLE_SWAGGER=false
JWT_SECRET=your-shared-jwt-secret
JWT_ISSUER=proodos-auth
JWT_AUDIENCE=proodos-be
JWT_ACCESS_ALGORITHM=HS256

DB_HOST=your-db-host
DB_PORT=1433
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# SQL Server options
DB_ENCRYPT=true
DB_TRUST_CERT=false

# Optional role mapping for route-level authorization middleware
# ADMIN_ROLES=admin

# Optional local root for relative variation HTML assets used by /landings/:id/export-index
# Default fallback: ../Proodos-FE/preview-assets
# LANDING_EXPORT_ASSETS_ROOT=

# Optional public base path injected into export-index asset hrefs.
# Default: Proodos-FE/preview-assets
# LANDING_EXPORT_ASSETS_BASE_PATH=
